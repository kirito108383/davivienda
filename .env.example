# Base de datos (PostgreSQL)
# Obtén tu DATABASE_URL de Neon.tech (gratuito) o cualquier proveedor PostgreSQL
DATABASE_URL=postgresql://usuario:password@host:puerto/database

# Entorno
NODE_ENV=production

# Opcional: Stripe para pagos reales
# STRIPE_SECRET_KEY=sk_test_...
# STRIPE_PUBLISHABLE_KEY=pk_test_...

# Opcional: Token de Replit para integración Stripe
# REPLIT_DOMAINS=tu-dominio.replit.app